<?xml version="1.0" encoding="utf-8"?>
<!-- Backup is disabled (android:allowBackup="false"), so <cloud-backup> is a
     backstop in case it is ever re-enabled. <device-transfer> is live policy,
     not a backstop: on Android 12+ allowBackup="false" does not reliably block
     device-to-device transfer (SPEC §9, privacy). Excludes match exact paths, so
     questloop.db's SQLite sidecars (-wal/-shm/-journal, which carry recent
     writes) must be listed alongside it in both sections. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="questloop.db" />
        <exclude domain="database" path="questloop.db-wal" />
        <exclude domain="database" path="questloop.db-shm" />
        <exclude domain="database" path="questloop.db-journal" />
        <exclude domain="file" path="datastore/questloop_profile.preferences_pb" />
        <exclude domain="file" path="ai_diagnostics.log" />
        <exclude domain="sharedpref" path="questloop_secure.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="questloop.db" />
        <exclude domain="database" path="questloop.db-wal" />
        <exclude domain="database" path="questloop.db-shm" />
        <exclude domain="database" path="questloop.db-journal" />
        <exclude domain="file" path="datastore/questloop_profile.preferences_pb" />
        <exclude domain="file" path="ai_diagnostics.log" />
        <exclude domain="sharedpref" path="questloop_secure.xml" />
    </device-transfer>
</data-extraction-rules>
