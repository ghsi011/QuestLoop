<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for AI quest suggestions (OpenRouter API key, or OpenAI via the
         ChatGPT OAuth login). Only used when the user enables AI and signs in; all
         other features work offline. The OpenAI login also runs a short-lived
         loopback server (127.0.0.1:1455) to catch the OAuth redirect — that needs
         no extra permission. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Daily reminder notifications (opt-in, Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Re-arm reminders after device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Brief CPU wake lock so an in-flight AI request survives the screen turning off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Opt-in only: read the device calendar's free/busy to budget today's plan
         (SPEC §10). Read-only, on-device — no calendar data ever leaves the phone. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- Privacy posture (SPEC §9): the user's habit/goal/quest data and the AI key
         stay on this device. Backup is disabled so nothing is copied to cloud/adb
         backup or device-transfer; the rule files below are an explicit backstop
         in case backup is ever re-enabled. -->
    <application
        android:name=".QuestLoopApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuestLoop">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.QuestLoop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".reminders.ReminderReceiver"
            android:exported="false" />
        <receiver
            android:name=".reminders.ReminderActionReceiver"
            android:exported="false" />
        <receiver
            android:name=".reminders.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.QuestWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quest_widget_info" />
        </receiver>
        <!-- Self-healing alarm target: re-renders the widget at midnight and
             day-part boundaries so the morning glance never shows yesterday. -->
        <receiver
            android:name=".widget.WidgetRefreshReceiver"
            android:exported="false" />
    </application>

</manifest>
