<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for AI quest suggestions (OpenRouter API key, or OpenAI via the
         ChatGPT OAuth login). Only used when the user enables AI and signs in; all
         other features work offline. The OpenAI login also runs a short-lived
         loopback server (127.0.0.1:1455) to catch the OAuth redirect — that needs
         no extra permission. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Daily reminder notifications (opt-in, Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Re-arm reminders after device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Brief CPU wake lock so an in-flight AI request survives the screen turning off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Opt-in only: read the device calendar's free/busy to budget today's plan
         (SPEC §10). Read-only, on-device — no calendar data ever leaves the phone. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- Privacy posture (SPEC §9): the user's habit/goal/quest data and the AI key
         stay on this device. Backup is disabled so nothing is copied to cloud/adb
         backup or device-transfer; the rule files below are an explicit backstop
         in case backup is ever re-enabled. -->
    <application
        android:name=".QuestLoopApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuestLoop">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.QuestLoop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".reminders.ReminderReceiver"
            android:exported="false" />
        <receiver
            android:name=".reminders.ReminderActionReceiver"
            android:exported="false" />
        <!-- Per-quest timed reminders (quests scheduled at set times of day) and
             their notification "Mark done" action. -->
        <receiver
            android:name=".reminders.QuestReminderReceiver"
            android:exported="false" />
        <receiver
            android:name=".reminders.QuestReminderActionReceiver"
            android:exported="false" />
        <!-- Re-arms the reminder alarms whenever their fixed trigger instants go
             stale: reboot, timezone change, or a clock correction. All three are
             protected system broadcasts, exempt from implicit-broadcast limits. -->
        <receiver
            android:name=".reminders.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
            </intent-filter>
        </receiver>

        <!-- Quick-add dialog opened from the home-screen widget's "Add a quest" box.
             Transparent window hosting a Compose Dialog; not exported (only our own
             widget launches it via an explicit intent). taskAffinity="" keeps it in
             its own task so it floats over the home screen instead of joining (and
             surfacing) the app's MainActivity task. -->
        <activity
            android:name=".widget.AddQuestActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/Theme.QuestLoop.Transparent" />

        <!-- Completion menu opened from a widget task row. Same over-the-home-screen
             transparent dialog; carries the quest id as an intent extra. NOT singleTop:
             each row carries a distinct quest, so every tap gets a fresh instance (and
             a fresh ViewModel reading its own intent) rather than reusing a stale one. -->
        <activity
            android:name=".widget.CompleteQuestActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.QuestLoop.Transparent" />

        <receiver
            android:name=".widget.QuestWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quest_widget_info" />
        </receiver>
        <!-- Self-healing alarm target: re-renders the widget at midnight and
             day-part boundaries so the morning glance never shows yesterday. -->
        <receiver
            android:name=".widget.WidgetRefreshReceiver"
            android:exported="false" />
    </application>

</manifest>
