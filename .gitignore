# Gradle
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# Android / IDE
*.iml
.idea/
local.properties
captures/
.cxx/

# Release signing — never commit keystores or their passwords. Signing material
# comes from CI secrets or a local (untracked) keystore.properties.
*.jks
*.keystore
keystore.properties

# OS
.DS_Store

# Logs
*.log

# graphify knowledge graph — commit the queryable graph + report so cloud
# agents (which check out the repo) inherit them; ignore the local-only
# artifacts (1.8 MB HTML viewer, extraction cache, cost/manifest, scratch).
graphify-out/*
!graphify-out/graph.json
!graphify-out/GRAPH_REPORT.md
